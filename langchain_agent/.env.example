# Configuration template for development environment
# Copy this file to .env and fill in your actual values
# Monorepo catalog: ../.env.example

# LangChain agent ports (loopback only, not exposed externally):
#   :8888  — main uvicorn HTTP server (launched by run-bank.sh)
#   :8889  — chat streaming WebSocket (WEBSOCKET_PORT, defaulted in src/config/settings.py)
#   :8890  — health + /inspector/mcp-host JSON sidecar (HEALTH_HTTP_PORT, defaulted in src/main.py)
#
# Defaults below match the code defaults. Override here only if you need to.
HEALTH_HTTP_PORT=8890

ENVIRONMENT=
DEBUG=
LOG_LEVEL=
WEBSOCKET_PORT=8889
LANGCHAIN_VERBOSE=
# WebSocket streaming during agent turns (MCP tool lifecycle + LLM tokens; ChatOpenAI only)
LANGCHAIN_STREAM_MCP_TOOL_EVENTS=true
LANGCHAIN_STREAM_LLM_TOKENS=true
# Conversation trimming: maximum number of messages to keep per session (Stage 1).
# NOTE: token_counter=len counts messages, not tokens — this is a message-count cap,
# not a token-budget. A value of 4096 keeps up to 4096 messages before trimming.
# Set this BELOW max_messages_per_session (default 100) to activate Stage-1 trimming.
# Example: set to 20 to trim to the 20 most recent messages before the count cap runs.
LANGCHAIN_MAX_CONTEXT_TOKENS=4096
LANGCHAIN_MODEL_NAME=
PINGONE_REDIRECT_URI=
SESSION_TIMEOUT_MINUTES=

# PingOne AI IAM Core Configuration
# Replace with your actual ForgeRock tenant configuration
PINGONE_BASE_URL=
PINGONE_CLIENT_REGISTRATION_ENDPOINT=
PINGONE_TOKEN_ENDPOINT=
PINGONE_AUTHORIZATION_ENDPOINT=
PINGONE_DEFAULT_SCOPE=
PINGONE_REALM=

# Security Configuration
# Generate new keys using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=
ENCRYPTION_SALT=

# API Keys
# Get your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MCP Server Configuration (add as needed)
MCP_SERVER_BANKING_ENDPOINT=
MCP_SERVER_BANKING_CAPABILITIES=
MCP_SERVER_BANKING_AUTH_REQUIRED=

# MCP_SERVER_GITHUB_ENDPOINT=
# MCP_SERVER_GITHUB_CAPABILITIES=
# MCP_SERVER_GITHUB_AUTH_REQUIRED=

# MCP_SERVER_SLACK_ENDPOINT=
# MCP_SERVER_SLACK_CAPABILITIES=
# MCP_SERVER_SLACK_AUTH_REQUIRED=