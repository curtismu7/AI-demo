# banking-mcp-invest — environment variables
# Copy to .env and fill in real values

PORT=8081
HOST=0.0.0.0

# Resource URI — must match what agents use as `audience` when exchanging for this server's token
MCP_SERVER_RESOURCE_URI=https://mcp-invest.bxf.com
MCP_SERVER_RESOURCE_NAME=Super Banking MCP Server (mcp-invest)

# PingOne
PINGONE_ENVIRONMENT_ID=your-pingone-env-id
PINGONE_REGION=com

# Banking BFF (used by tool handlers)
BANKING_API_BASE_URL=http://localhost:3001
