# OpenAI Agents SDK agent service
AGENT_HOST=127.0.0.1
AGENT_PORT=8891

# BFF internal tool endpoint (set by BFF at request time; not configured here)
# BFF_TOOL_URL=http://127.0.0.1:3001/internal/agent-tool
# BFF_INTERNAL_SECRET=<set in demo_api_server/.env>

# OpenAI model
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=<your-openai-api-key>
