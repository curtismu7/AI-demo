{
  "name": "banking-demo",
  "version": "1.3.1",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "test": "bash scripts/run-all-tests.sh",
    "test:api-server": "cd banking_api_server && npm test -- --forceExit",
    "test:mcp-server": "cd banking_mcp_server && npm run test:unit",
    "test:mcp-server:integration": "cd banking_mcp_server && npm run test:integration",
    "test:ui": "cd banking_api_ui && CI=true npm test -- --watchAll=false --passWithNoTests",
    "test:agent": "cd langchain_agent && bash scripts/run-pytest.sh",
    "test:agent:full": "cd langchain_agent && bash scripts/run-pytest.sh tests/",
    "test:agent-ui": "cd langchain_agent/frontend && npm run test:ci",
    "test:mcp-inspector": "cd banking_api_server && npm test -- --testPathPattern=mcp-inspector --forceExit",
    "test:bff-tokens": "cd banking_api_server && npm test -- --testPathPattern='redisWireUrl|bffSessionGating' --forceExit --verbose",
    "test:session": "cd banking_api_server && npm run test:session",
    "test:e2e:ui": "cd banking_api_ui && npm run test:e2e:ci",
    "test:e2e:ui:smoke": "cd banking_api_ui && npm run test:e2e:ui:smoke",
    "release": "node scripts/release.js",
    "setup:fresh": "cd banking_api_server && node scripts/setupFresh.js",
    "import": "cd banking_api_server && node scripts/importMigrationBundle.js",
    "export": "cd banking_api_server && node scripts/exportMigrationBundle.js",
    "reset": "cd banking_api_server && node scripts/setupFresh.js --clean --reset-pingone",
    "reset:import": "cd banking_api_server && node scripts/setupFresh.js --clean --reset-pingone",
    "uninstall": "cd banking_api_server && node scripts/uninstall.js",
    "pingone:bootstrap": "cd banking_api_server && node scripts/bootstrapPingOne.js",
    "pingone:wipe": "cd banking_api_server && node scripts/bootstrapPingOne.js --wipe-environment",
    "pingone:recreate": "cd banking_api_server && node scripts/bootstrapPingOne.js --recreate-apps",
    "pingone:bootstrap:legacy-manifest": "node scripts/pingone-bootstrap.js",
    "pingone:bootstrap:probe": "node scripts/pingone-bootstrap.js --probe",
    "prepare": "husky"
  },
  "dependencies": {
    "nodemailer": "^8.0.4",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "husky": "^9.1.7",
    "i": "^0.3.7",
    "lint-staged": "^16.4.0",
    "npm": "^11.14.1",
    "or": "^0.2.0"
  }
}
