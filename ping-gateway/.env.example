# ─── PingGateway MCP Route Config ───────────────────────────────────────────
# Copy to .env and fill in values. All &{VAR} references in route JSON read
# from the process environment via PingGateway property substitution.

# ─── Inbound token validation ────────────────────────────────────────────────
# PingOne introspection endpoint
PINGONE_INTROSPECTION_ENDPOINT=https://auth.pingone.com/d02d2305-f445-406d-82ee-7cdbf6eeabfd/as/introspect

# Client used to introspect inbound mcpgateway.ping.demo tokens.
# Must be the issuing client or a resource server that owns the audience.
# Use the MCP exchanger client (same as the Node gateway).
INTROSPECT_CLIENT_ID=d3f8fead-b81d-46f9-bba5-051e493cea0e
# Secret mapped to "introspect.client.secret" by SystemAndEnvSecretStore (PLAIN format)
INTROSPECT_CLIENT_SECRET=<exchanger-client-secret>

# ─── Inbound gateway resource identity ───────────────────────────────────────
# Audience the inbound token must carry. Must match McpProtectionFilter.resourceId.
PG_GATEWAY_RESOURCE_URI=mcpgateway.ping.demo

# Scope required on the inbound token (used by both primary and secondary routes)
PG_INBOUND_SCOPE=banking:mcp:invoke

# ─── Token exchange (gateway → OLB backend) ──────────────────────────────────
PG_OLB_RESOURCE_URI=mcpserver.ping.demo
PG_OLB_SCOPE=banking:mcp:invoke

# PingOne token endpoint for RFC 8693 exchange
PINGONE_TOKEN_ENDPOINT=https://auth.pingone.com/d02d2305-f445-406d-82ee-7cdbf6eeabfd/as/token

# Client performing the exchange. Reuses the existing MCP exchanger app.
TE_CLIENT_ID=d3f8fead-b81d-46f9-bba5-051e493cea0e
# Secret mapped to "te.client.secret" by SystemAndEnvSecretStore (PLAIN format)
TE_CLIENT_SECRET=<exchanger-client-secret>

# ─── Token exchange (gateway → Invest backend) ───────────────────────────────
PG_INVEST_RESOURCE_URI=mcp-invest.ping.demo
PG_INVEST_SCOPE=banking:mcp:invoke

# ─── Backend URLs ─────────────────────────────────────────────────────────────
# Use host.docker.internal to reach services running on the macOS host.
# Change to service DNS names for Kubernetes.
PG_OLB_BACKEND_URL=http://host.docker.internal:8080
PG_INVEST_BACKEND_URL=http://host.docker.internal:8081

# ─── PingOne Authorize (P1AZ) — Decision Endpoints API ───────────────────────
# Full URL including decision endpoint ID.
# PingOne Console → Authorization → Decision Endpoints → copy URL
P1AZ_DECISION_ENDPOINT_URL=https://api.pingone.com/v1/environments/<envId>/decisionEndpoints/<endpointId>

# Worker app client credentials — the Groovy ScriptableFilter acquires and refreshes
# the bearer token itself via client_credentials grant (no static token needed).
# The worker app must have the DaVinci Authorize role in PingOne.
P1AZ_WORKER_CLIENT_ID=<worker-client-id>
P1AZ_WORKER_CLIENT_SECRET=<worker-client-secret>
