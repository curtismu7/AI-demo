# banking-agent-service — environment variables
# Copy to .env and fill in real values

# =============================================================================
# SERVER
# =============================================================================
PORT=3006
HOST=0.0.0.0

# =============================================================================
# AGENT1 OAUTH CLIENT (agent1 in PingOne)
# Used to acquire the actor_token for RFC 8693 token exchange.
# Create a Worker Application in PingOne with grant_type=token-exchange allowed.
# =============================================================================
AGENT_CLIENT_ID=your-agent1-client-id
AGENT_CLIENT_SECRET=your-agent1-client-secret

# =============================================================================
# PINGONE
# =============================================================================
PINGONE_ENVIRONMENT_ID=your-pingone-env-id
PINGONE_TOKEN_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/token

# =============================================================================
# MCP GATEWAY
# =============================================================================
MCP_GATEWAY_WS_URL=ws://localhost:3005
MCP_GW_RESOURCE_URI=https://api.ping.demo

# =============================================================================
# LLM PROVIDER
# Options: anthropic, openai, none (echo mode — no API key needed)
# =============================================================================
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# =============================================================================
# PKI CREDS (Phase G — optional)
# When true, agent uses private_key_jwt instead of client_secret.
# Requires AGENT_CERT_PATH pointing to a PKCS#12 certificate.
# =============================================================================
USE_PKI_AGENT_CREDS=false
AGENT_CERT_PATH=
