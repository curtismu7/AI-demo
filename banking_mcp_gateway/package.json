{
  "name": "banking-mcp-gateway",
  "version": "1.0.0",
  "description": "MCP Gateway — RFC 9728-facing protected resource in front of the banking MCP server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && npm run build",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.2.2",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "forceExit": true
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  }
}
