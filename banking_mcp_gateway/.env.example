# banking-mcp-gateway — environment variables
# Copy to .env and fill in real values

# =============================================================================
# SERVER
# =============================================================================
PORT=3005
HOST=0.0.0.0

# =============================================================================
# GATEWAY OAUTH CLIENT (mcp-gw in PingOne)
# This client's credentials are used as the actor token source in RFC 8693 re-exchange.
# Create a Worker Application in PingOne with grant_type=token-exchange allowed.
# =============================================================================
MCP_GW_CLIENT_ID=your-mcp-gw-client-id
MCP_GW_CLIENT_SECRET=your-mcp-gw-client-secret

# =============================================================================
# PINGONE
# =============================================================================
PINGONE_ENVIRONMENT_ID=your-pingone-env-id
PINGONE_REGION=com
PINGONE_TOKEN_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/token

# =============================================================================
# GATEWAY RESOURCE URI
# This is the `aud` value that agent1 must request when exchanging for a GW-scoped token.
# Register this as the resource_uri on the MCP Gateway Resource in PingOne.
# =============================================================================
MCP_GW_RESOURCE_URI=https://api.ping.demo

# =============================================================================
# BACKEND MCP SERVERS
# =============================================================================
# mcp-olb (banking_mcp_server)
MCP_OLB_WS_URL=ws://localhost:8080
MCP_OLB_RESOURCE_URI=https://api.ping.demo

# mcp-invest (banking_mcp_invest)
MCP_INVEST_WS_URL=ws://localhost:8081
MCP_INVEST_RESOURCE_URI=https://mcp-invest.bxf.com

# =============================================================================
# PINGAUTHORIZE (optional — leave blank to skip PA guard)
# When set: tools/list is guarded by PA client-cred check,
# tools/call is guarded by PA per-tool scope check.
# =============================================================================
PINGAUTHORIZE_ENDPOINT=
PINGAUTHORIZE_WORKER_ID=

# =============================================================================
# HITL SERVICE (optional — leave blank to return HITL error without creating a challenge)
# When set: INDETERMINATE PA decisions create a challenge in the HITL service
# and return the challengeId to the agent for retry.
# =============================================================================
HITL_SERVICE_URL=http://localhost:3009

# =============================================================================
# OPTIONAL TUNING
# =============================================================================
GW_TOOL_CALL_TIMEOUT_MS=30000

# =============================================================================
# PORTABLE ENCRYPTED CREDENTIAL VAULT (Phase 269)
# =============================================================================
# The gateway can read MCP_GW_*, PROVIDER_*, HELIX_*, and BFF_INTERNAL_*
# entries from a shared encrypted vault (secrets.vault at repo root). Set
# VAULT_PATH if your vault lives elsewhere; set VAULT_PASSWORD to unlock the
# vault at startup. The gateway deletes VAULT_PASSWORD from process.env
# immediately after opening the vault.
#
# NOTE: In a standard install, banking_mcp_gateway/.env is typically a
# symlink to banking_api_server/.env (created by run-bank.sh's
# ensure_service_env helper). Plan 05's setupFresh.js writes VAULT_PATH into
# the BFF's .env, which the gateway then sees via the symlink. You do NOT
# need to set VAULT_PATH in both places.
#
# ⚠️  No password recovery — see banking_api_server/.env.example.
#
# Quote secrets per CLAUDE.md rule (special chars ~ . - break shell parsing):
#   VAULT_PATH="/etc/banking/secrets.vault"
#   VAULT_PASSWORD="your-strong-passphrase-here"
#
# Allowlist regex for vault keys: /^(MCP_GW_|PROVIDER_|HELIX_|BFF_INTERNAL_)[A-Z0-9_]+$/
# Entries outside this allowlist are LOGGED and SKIPPED (no env injection).
#
# Vercel: skipped when VERCEL=1.
# =============================================================================
# VAULT_PATH=
# VAULT_PASSWORD=
