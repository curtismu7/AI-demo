# banking-mcp-gateway — environment variables
# Copy to .env and fill in real values

# =============================================================================
# SERVER
# =============================================================================
PORT=3005
HOST=0.0.0.0

# =============================================================================
# GATEWAY OAUTH CLIENT (mcp-gw in PingOne)
# This client's credentials are used as the actor token source in RFC 8693 re-exchange.
# Create a Worker Application in PingOne with grant_type=token-exchange allowed.
# =============================================================================
MCP_GW_CLIENT_ID=your-mcp-gw-client-id
MCP_GW_CLIENT_SECRET=your-mcp-gw-client-secret

# =============================================================================
# PINGONE
# =============================================================================
PINGONE_ENVIRONMENT_ID=your-pingone-env-id
PINGONE_REGION=com
PINGONE_TOKEN_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/token

# =============================================================================
# GATEWAY RESOURCE URI
# This is the `aud` value that agent1 must request when exchanging for a GW-scoped token.
# Register this as the resource_uri on the MCP Gateway Resource in PingOne.
# =============================================================================
MCP_GW_RESOURCE_URI=https://mcp-gw.bxf.com

# =============================================================================
# BACKEND MCP SERVERS
# =============================================================================
# mcp-olb (banking_mcp_server)
MCP_OLB_WS_URL=ws://localhost:8080
MCP_OLB_RESOURCE_URI=https://mcp-olb.bxf.com

# mcp-invest (banking_mcp_invest)
MCP_INVEST_WS_URL=ws://localhost:8081
MCP_INVEST_RESOURCE_URI=https://mcp-invest.bxf.com

# =============================================================================
# PINGAUTHORIZE (optional — leave blank to skip PA guard)
# When set: tools/list is guarded by PA client-cred check,
# tools/call is guarded by PA per-tool scope check.
# =============================================================================
PINGAUTHORIZE_ENDPOINT=
PINGAUTHORIZE_WORKER_ID=

# =============================================================================
# HITL SERVICE (optional — leave blank to return HITL error without creating a challenge)
# When set: INDETERMINATE PA decisions create a challenge in the HITL service
# and return the challengeId to the agent for retry.
# =============================================================================
HITL_SERVICE_URL=http://localhost:3009

# =============================================================================
# OPTIONAL TUNING
# =============================================================================
GW_TOOL_CALL_TIMEOUT_MS=30000
