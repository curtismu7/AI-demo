# banking_api_ui — copy to .env (local). HTTPS via mkcert on api.ping.demo.
# Full catalog: ../.env.example (REACT_APP_* must match PingOne redirect URIs)

# Local dev runs the UI on https://api.ping.demo:4000 via run-bank.sh.
PORT=4000

# Default API base URL: leave empty so axios uses same origin; src/setupProxy.js
# proxies /api → REACT_APP_API_PORT (default 3001) so session cookies match OAuth.
# If set explicitly, axios still uses the proxy when the page is on the same host
# with a different port (see resolveApiBaseUrl.js).
REACT_APP_API_URL=https://api.ping.demo:3001

# Must match the URL users open in the browser and PingOne Sign Off / post-logout URIs.
# Default local host is api.ping.demo (HTTPS via mkcert).
REACT_APP_CLIENT_URL=https://api.ping.demo:4000

REACT_APP_ENDUSER_AUDIENCE=banking_jk_enduser
REACT_APP_AI_AGENT_AUDIENCE=banking_mcp_01_JK

# Optional: MCP inspector UI served by the LangChain agent health sidecar (loopback only).
# Default port 8890 (HEALTH_HTTP_PORT in langchain_agent). The BFF also proxies this at
# /api/mcp/inspector/langchain-host so the browser can use HTTPS.
# REACT_APP_LANGCHAIN_INSPECTOR_URL=http://localhost:8890/inspector/mcp-host
