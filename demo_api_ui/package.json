{
  "name": "banking-admin-client",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@monaco-editor/react": "^4.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "mermaid": "^11.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.0",
    "react-scripts": "^5.0.1",
    "react-table": "^7.8.0",
    "react-toastify": "^11.1.0",
    "web-vitals": "^5.2.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --reporters=default --reporters=./src/reporters/markdownReporter.js",
    "test:unit": "react-scripts test --watchAll=false --reporters=default --reporters=./src/reporters/markdownReporter.js",
    "eject": "react-scripts eject",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:ci:reuse": "CI=true PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:api": "playwright test --config=playwright.api.config.js --reporter=list",
    "test:e2e:session": "playwright test tests/e2e/session-regression.spec.js --config=playwright.api.config.js --reporter=list",
    "test:e2e:admin": "playwright test tests/e2e/admin-dashboard.spec.js --reporter=list",
    "test:e2e:security": "playwright test tests/e2e/security-settings.spec.js --reporter=list",
    "test:e2e:agent": "playwright test tests/e2e/banking-agent.spec.js --reporter=list",
    "test:e2e:customer": "playwright test tests/e2e/customer-dashboard.spec.js --reporter=list",
    "test:e2e:landing": "playwright test tests/e2e/landing-marketing.spec.js --reporter=list",
    "test:e2e:ui:smoke": "playwright test tests/e2e/customer-dashboard.spec.js tests/e2e/landing-marketing.spec.js --reporter=list",
    "test:e2e:real": "playwright test --config=playwright.real.config.js --reporter=list",
    "test:e2e:real:local": "E2E_BASE_URL=http://localhost:3000 playwright test --config=playwright.real.config.js --reporter=list",
    "test:e2e:smoke": "playwright test tests/e2e/url-smoke.spec.js"
  },
  "lint:modal-overlay-pattern": "node ../../.agents/skills/modal-overlay-pattern/lint-modal-overlay-pattern.js",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/dom": "^10.4.1",
    "@types/jest": "^30.0.0",
    "browserslist": "^4.28.2",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "typescript": "^5.1.6",
    "wait-on": "^9.0.5"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-restricted-globals": [
        "warn",
        {
          "name": "confirm",
          "message": "Use <ConfirmModal> with local state instead of window.confirm(). See docs/superpowers/specs/2026-05-24-ui-feedback-consistency-design.md"
        }
      ],
      "no-restricted-imports": [
        "warn",
        {
          "paths": [
            {
              "name": "react-toastify",
              "importNames": [
                "toast"
              ],
              "message": "Import notifyError/notifySuccess/notifyInfo/notifyWarning from utils/appToast instead. Direct toast() is only allowed in utils/appToast.js, utils/dashboardToast.js, and components/ErrorToast.js."
            }
          ]
        }
      ]
    },
    "overrides": [
      {
        "files": [
          "src/utils/appToast.js",
          "src/utils/dashboardToast.js",
          "src/components/ErrorToast.js"
        ],
        "rules": {
          "no-restricted-imports": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "jest": {
    "resetMocks": false,
    "transformIgnorePatterns": [
      "/node_modules/(?!(axios)/)"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/fileMock.js",
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write"
    ]
  }
}
