      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- PingOne Auth -->
    <mxCell id="pingone-auth" value="Auth Code + PKCE&#xa;POST /as/token&#xa;→ Access Token + ID Token + Refresh Token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="520" y="140" width="260" height="60" as="geometry" />
