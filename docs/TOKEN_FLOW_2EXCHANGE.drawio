    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- STEP 4: EXCHANGE #2 -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="step4-label" value="④ Exchange #2 — Agent Token → MCP Delegation" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#6a3daa;whiteSpace=wrap;" vertex="1" parent="1">
