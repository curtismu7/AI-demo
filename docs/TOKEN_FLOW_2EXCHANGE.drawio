    </mxCell>

    <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bff-ex2-req" target="mcp-cc-token" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Final MCP Token -->
    <mxCell id="final-mcp-token" value="✔ Final MCP Token&#xa;sub: &lt;user-sub&gt;  (preserved end-to-end)&#xa;aud: resource-server.pingdemo.com&#xa;act: {&#xa;  sub: &quot;mcp-exchanger-client-id&quot;,&#xa;  act: { sub: &quot;ai-agent-client-id&quot; }&#xa;}&#xa;scope: banking:read  (narrowed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#9673a6;fontSize=9;align=left;" vertex="1" parent="1">
