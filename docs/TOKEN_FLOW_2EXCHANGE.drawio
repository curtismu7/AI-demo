    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- STEP 5: MCP TOOL CALL -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="step5-label" value="⑤ MCP Tool Call — Bearer = Final MCP Token" style="text;html=1;strokeColor=none;fillColor=#f8cecc;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#921919;whiteSpace=wrap;" vertex="1" parent="1">
