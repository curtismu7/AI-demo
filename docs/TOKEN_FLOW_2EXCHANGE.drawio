    </mxCell>

    <mxCell id="e3b" value="stored server-side&#xa;httpOnly session" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#276821;" edge="1" source="user-at" target="bff-authorize" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- STEP 2: AGENT CALL INITIATED -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="step2-label" value="② AI Agent Invoked — POST /api/banking-agent/message" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#6b4e00;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="230" y="320" width="400" height="24" as="geometry" />
    </mxCell>

    <mxCell id="user-prompt" value="User sends chat prompt" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="80" y="355" width="120" height="50" as="geometry" />
    </mxCell>

    <mxCell id="bff-agent" value="POST /api/banking-agent/message&#xa;Check: scopeCount ≥ 5&#xa;Check: mcp_resource_uri set&#xa;Check: may_act.sub = AI Agent client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="355" width="220" height="70" as="geometry" />
    </mxCell>

    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user-prompt" target="bff-agent" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- STEP 3: EXCHANGE #1 -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="step3-label" value="③ Exchange #1 — User AT → AI Agent Delegation" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#6a3daa;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="230" y="445" width="400" height="24" as="geometry" />
    </mxCell>

    <mxCell id="ai-cc-token" value="AI Agent CC Token&#xa;Client Credentials&#xa;aud: agent-gateway.pingdemo.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="520" y="445" width="240" height="60" as="geometry" />
    </mxCell>

    <mxCell id="bff-ex1-req" value="RFC 8693 Exchange #1&#xa;subject_token = User AT&#xa;actor_token = AI Agent CC Token&#xa;audience = ai-agent.pingdemo.com&#xa;client_id = PINGONE_AI_AGENT_CLIENT_ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;" vertex="1" parent="1">
