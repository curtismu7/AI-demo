    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- STEP 1: USER LOGIN -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <mxCell id="step1-label" value="① User Login — Authorization Code + PKCE" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#6b4e00;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="230" y="100" width="340" height="24" as="geometry" />
    </mxCell>

    <!-- User clicks Login -->
