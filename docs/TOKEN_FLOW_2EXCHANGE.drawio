      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- User AT box -->
    <mxCell id="user-at" value="✔ User Access Token&#xa;aud: ai-agent.pingdemo.com&#xa;scope: openid profile email offline_access&#xa;        banking:read banking:write banking:ai:agent&#xa;may_act.sub: ai-agent-client-id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;" vertex="1" parent="1">
