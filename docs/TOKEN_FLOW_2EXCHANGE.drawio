    <mxCell id="mcp-cc-token" value="MCP Exchanger CC Token&#xa;Client Credentials&#xa;aud: mcp-gateway.pingdemo.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="520" y="680" width="240" height="60" as="geometry" />
    </mxCell>

    <mxCell id="bff-ex2-req" value="RFC 8693 Exchange #2&#xa;subject_token = Intermediate Token&#xa;actor_token = MCP Exchanger CC Token&#xa;audience = resource-server.pingdemo.com&#xa;scope = banking:read  (tool-specific)&#xa;client_id = MCP_TOKEN_EXCHANGER_CLIENT_ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;" vertex="1" parent="1">
      <mxGeometry x="240" y="715" width="240" height="90" as="geometry" />
    </mxCell>

    <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="intermediate-token" target="bff-ex2-req" parent="1">
