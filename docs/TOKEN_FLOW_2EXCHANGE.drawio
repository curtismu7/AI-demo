    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="bff-ex1-req" target="ai-cc-token" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Intermediate Agent Token -->
    <mxCell id="intermediate-token" value="✔ Intermediate Agent Token&#xa;sub: &lt;user-sub&gt;  (preserved)&#xa;aud: ai-agent.pingdemo.com&#xa;act: { sub: &quot;ai-agent-client-id&quot; }&#xa;scope: banking:read banking:write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#9673a6;fontSize=9;align=left;" vertex="1" parent="1">
