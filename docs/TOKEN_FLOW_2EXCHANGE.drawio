      <mxGeometry x="80" y="140" width="120" height="50" as="geometry" />
    </mxCell>

    <!-- BFF /authorize redirect -->
    <mxCell id="bff-authorize" value="GET /api/auth/oauth/user/login&#xa;PKCE: code_challenge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="140" width="200" height="50" as="geometry" />
