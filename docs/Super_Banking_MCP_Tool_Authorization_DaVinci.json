            "properties": {
              "customHTML": {
                "value": "<div data-skcomponent=\"skrisk\" data-skenvironmentid=\"{{global.companyId}}\" data-skcollectBehavioralData=\"true\" data-skpropertyname=\"riskPayload\" data-skuniversaldeviceidentification=\"false\" data-skpingidagent=\"true\" data-skpingidagenttimeout=\"2000\" data-skpingidagentport=\"\"></div>\n<div class=\"end-user-nano\">\n  <div class=\"min-vh-100 bg-light d-flex flex-column align-items-center py-4\">\n    <div style=\"max-width: 560px; min-width: 400px; width: 100%\">\n      <div class=\"card rounded-3 my-5\">\n        <main aria-labelledby=\"title\">\n          <div class=\"card-body rounded-3 p-5 d-flex flex-column\">\n            <img class=\"companyLogo align-self-center mb-5\" src=\"{{global.variables.companyLogo}}\" alt=\"{{global.variables.companyName}}\">\n            <h1 id=\"title\" class=\"text-center mb-2\">MCP Tool Authorization</h1>\n            <p class=\"text-muted text-center mb-4\">Review and authorize the AI agent's tool invocation request.</p>\n            <p class=\"text-danger mdi mdi-alert-circle text-center\" id=\"feedbackError\" data-id=\"feedback\" data-skcomponent=\"skerror\" aria-live=\"assertive\"></p>\n            <form id=\"mcpAuthForm\" aria-labelledby=\"title\" data-id=\"mcpAuthForm\">\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">User ID (PingOne sub)</label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"userId\" name=\"userId\" placeholder=\"PingOne user ID (sub claim)\" aria-required=\"true\">\n              </div>\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">Tool Name</label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"toolName\" name=\"toolName\" placeholder=\"e.g. banking_get_accounts\" aria-required=\"true\">\n              </div>\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">Token Audience</label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"tokenAudience\" name=\"tokenAudience\" placeholder=\"aud claim from MCP access token\" aria-required=\"true\">\n              </div>\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">Actor Client ID (act.client_id)</label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"actClientId\" name=\"actClientId\" placeholder=\"Client ID of Super Banking BFF Admin\" aria-required=\"true\">\n              </div>\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">Nested Actor Client ID <span class=\"text-muted fw-normal\">(optional)</span></label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"nestedActClientId\" name=\"nestedActClientId\" placeholder=\"act.act.client_id for multi-hop delegation\">\n              </div>\n              <div class=\"mb-3\">\n                <label class=\"form-label fw-semibold\">MCP Resource URI</label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"mcpResourceUri\" name=\"mcpResourceUri\" placeholder=\"Expected MCP server URI\" aria-required=\"true\">\n              </div>\n              <div class=\"mb-4\">\n                <label class=\"form-label fw-semibold\">ACR <span class=\"text-muted fw-normal\">(optional)</span></label>\n                <input class=\"form-control rounded-3\" type=\"text\" id=\"acr\" name=\"acr\" placeholder=\"Authentication context class reference\">\n              </div>\n              <input type=\"hidden\" id=\"riskPayload\" name=\"riskPayload\" value=\"\">\n              <div class=\"d-flex flex-column\">\n                <button data-id=\"button\" type=\"submit\" class=\"btn btn-primary rounded-3 mb-3\" data-skcomponent=\"skbutton\" data-skbuttontype=\"form-submit\" id=\"btnEvaluate\" data-skform=\"mcpAuthForm\" data-skbuttonvalue=\"EVALUATE\">\n                  E