              "customScript": {
                "value": "const toggleButtonState = () => {\n    const required = ['userId', 'toolName', 'tokenAudience', 'actClientId', 'mcpResourceUri'];\n    const button = document.getElementById('btnEvaluate');\n    if (!button) return;\n    button.disabled = required.some(id => !document.getElementById(id)?.value.trim());\n};\n\nconst start = () => {\n    const first = document.getElementById('userId');\n    if (first) first.focus();\n    toggleButtonState();\n    setTimeout(toggleButtonState, 150);\n    setTimeout(toggleButtonState, 500);\n    ['userId', 'toolName', 'tokenAudience', 'actClientId', 'mcpResourceUri'].forEach(id => {\n        ['input', 'keyup', 'change'].forEach(evt => {\n            document.getElementById(id)?.addEventListener(evt, toggleButtonState);\n        });\n    });\n};\n\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', start);\n} else {\n    start();\n}"
