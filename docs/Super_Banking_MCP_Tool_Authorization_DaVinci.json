            "capabilityName": "customFunction",
            "type": "trigger",
            "properties": {
              "variableInputList": {
                "value": [
                  {
                    "name": "statements",
                    "preferredDataType": "object",
                    "value": "[\n  {\n    \"children\": [\n      {\n        \"text\": \"\"\n      },\n      {\n        \"type\": \"link\",\n        \"src\": \"pingIdentity.svg\",\n        \"url\": \"statements\",\n        \"data\": \"{{local.mc6auth01a.payload.output.statements}}\",\n        \"tooltip\": \"{{local.mc6auth01a.payload.output.statements}}\",\n        \"children\": [\n          {\n            \"text\": \"statements\"\n          }\n        ]\n      },\n      {\n        \"text\": \"\"\n      }\n    ]\n  }\n]"
                  },
                  {
                    "name": "decision",
                    "preferredDataType": "string",
                    "value": "[\n  {\n    \"children\": [\n      {\n        \"text\": \"\"\n      },\n      {\n        \"type\": \"link\",\n        \"src\": \"pingIdentity.svg\",\n        \"url\": \"status\",\n        \"data\": \"{{local.mc6auth01a.payload.output.status}}\",\n        \"tooltip\": \"{{local.mc6auth01a.payload.output.status}}\",\n        \"children\": [\n          {\n            \"text\": \"status\"\n          }\n        ]\n      },\n      {\n        \"text\": \"\"\n      }\n    ]\n  }\n]"
                  }
                ]
              },
              "code": {
                "value": "// Super Banking — Parse PingOne Authorize MCP Delegation Response\n// Processes authorization statements and extracts obligations.\n//\n// Decision routing (configure in the Evaluator node after this Functions node):\n//   local.mc8func01a.payload.output.denied === true           → Tool Authorization Denied node\n//   local.mc8func01a.payload.output.stepUpRequired === true   → Step-Up Required node\n//   local.mc8func01a.payload.output.hitlRequired === true     → Human Approval Required node\n//   (default)                                                 → Tool Authorized node\n//\n// Also route from the Decision Router evaluator (mc5eval02b) BEFORE this node:\n//   local.mc6auth01a.payload.output.status === 'DENY'         → Tool Authorization Denied (skip Functions)\n\nmodule.exports = async ({ params }) => {\n    const rawStatements = params.statements;\n    const decision = params.decision;\n\n    // Parse JSON-string payloads in each statement\n    const processedStatements = (rawStatements || []).map(item => {\n        let parsedPayload;\n        if (typeof item.payload === 'string' && item.payload.trim().length > 0) {\n            try {\n                parsedPayload = JSON.parse(item.payload);\n            } catch (e) {\n                parsedPayload = item.payload;\n            }\n        } else {\n            parsedPayload = item.payload || {};\n        }\n        return { ...item, payload: parsedPayload };\n    });\n\n    // Check for step-up MFA obligation\n    const stepUpRequired = processedStatements.some(s =>\n        s.payload && (\n            s.payload.stepUpRequired === true ||\n            s.payload.obligationName === 'stepUp' ||\n            s.payload.obligationName === 'mfa'\n        )\n    );\n\n    // Check for Human-In-The-Loop (HITL) obligation\n    // HITL is returned when the policy requires manual approval before tool execution\n    const hitlRequired = processedStatements.some(s =>\n        s.payload && (\n            s.payload.hitlRequired === true ||\n            s.payload.obligationName === 'hitl' ||\n            s.payload.obligationName === 'humanApproval'\n        )\n    );\n\n    const denied = decision === 'DENY';\n    const permitted = decision === 'PERMIT' && !stepUpRequired && !hitlRequired;\n\n    console.log('Super Banking MCP Tool Authorization Decision:', {\n        decision,\n        stepUpRequired,\n        hitlRequired,\n        denied,\n        permitted,\n        statementCount: processedStatements.length\n    });\n\n    return {\n        decision: decision || 'INDETERMINATE',\n        statements: processedStatements,\n        stepUpRequired,\n        hitlRequired,\n        denied,\n        permitted,\n        requiresAction: stepUpRequired || hitlRequired\n    };\n}"
              },
              "outputSchema": {
                "value": "{\n\t\"output\": {\n\t\t\"type\": \"object\",\n\t\t\"properties\": {\n\t\t\t\"decision\": { \"type\": \"string\" },\n\t\t\t\"statements\": { \"type\": \"object\" },\n\t\t\t\"stepUpRequired\": { \"type\": \"boolean\" },\n\t\t\t\"hitlRequired\": { \"type\": \"boolean\" },\n\t\t\t\"denied\": { \"type\": \"boolean\" },\n\t\t\t\"permitted\": { \"type\": \"boolean\" },\n\t\t\t\"requiresAction\": { \"type\": \"boolean\" }\n\t\t}\n\t}\n}"
              },
              "nodeTitle": {
                "value": "Parse MCP Authorize Response"
              }
            }
