              "customScript": {
                "value": "const setFieldFocus = (id) => {\n    const el = document.getElementById(id);\n    if (el) el.focus();\n};\n\nconst toggleButtonState = () => {\n    const username = document.getElementById('username');\n    const amount = document.getElementById('amount');\n    const txType = document.getElementById('transactionType');\n    const button = document.getElementById('btnAuthorize');\n    if (!button) return;\n    button.disabled = !(username?.value.trim() && amount?.value && parseFloat(amount.value) > 0 && txType?.value);\n};\n\nconst start = () => {\n    setFieldFocus('username');\n    toggleButtonState();\n    setTimeout(toggleButtonState, 150);\n    setTimeout(toggleButtonState, 500);\n    ['username', 'amount', 'transactionType'].forEach(id => {\n        ['input', 'keyup', 'change'].forEach(evt => {\n            document.getElementById(id)?.addEventListener(evt, toggleButtonState);\n        });\n    });\n};\n\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', start);\n} else {\n    start();\n}"
