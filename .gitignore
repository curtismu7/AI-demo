# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
**/dist/
**/build/

# Environment files — never commit secrets (templates named *.example are tracked)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.production
**/.env.development
**/.env.staging
.env.vercel
.env.replit
.envrc
**/.env.*
!.env.example
!.env.*.example
!**/.env.example
!**/.env.*.example

# Local Upstash / KV notes (often contain tokens)
upstash.md

# Key material & credential dumps
*.pem
*.p12
*.pfx
secrets/
credentials.json
*-credentials.json

# Logs
logs/
*.log
npm-debug.log*

# setup:fresh artifacts — contain demo passwords + management worker creds
# See banking_api_server/scripts/setupFresh.js + bootstrapPingOne.js
setup.log
setup-config.md

# Runtime
*.pid
*.sock
.DS_Store

# Config database (local SQLite — contains encrypted secrets)
banking_api_server/data/persistent/config.db
banking_api_server/data/persistent/config.db-shm
banking_api_server/data/persistent/config.db-wal
banking_api_server/data/persistent/agentIdentityMappings.json
banking_api_server/data/logs/

# Express session store (local SQLite — live session data, never commit)
banking_api_server/data/sessions.db
banking_api_server/data/sessions.db-shm
banking_api_server/data/sessions.db-wal

# Portable encrypted credential vault (Phase 269) — encrypted at rest but
# NEVER commit. Vault password is required to decrypt and lives only in
# the operator's head / 1Password / direnv. Encrypted-at-rest means an
# accidental commit is recoverable via password rotation, but .gitignore
# is the primary defense.
secrets.vault
secrets.vault.tmp
secrets.vault.audit.log

# Temporary test scripts
banking_api_server/_test_*.js

# TypeScript
*.tsbuildinfo

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
langchain_agent/.venv/

# Test coverage
coverage/
**/coverage/

# IDE
.vscode/
.idea/
# .claude/ root is ignored; exclude contents but allow skills/ subdirectory
.claude/*
!.claude/skills/
!.claude/skills/**

# SSL certs (generated locally via mkcert — never commit private keys)
certs/

# Misc
.DS_Store
Thumbs.db
banking_api_server/data/persistent/
.vercel

# Test artifacts
banking_mcp_server/tests/storage/test-banking-sessions-logging/
banking_mcp_server/tests/storage/**/

