banking-export-*.tar.gz.tmp.*

# Local archive folder for old/superseded artifacts
/.archive/

# Stale vault backups (encrypted secrets — never commit)
secrets.vault.stale-*.bak

# Local vault-password wrapper for run-bank.sh (no secret stored here; reads .env)
run-bank-local.sh

