demo_api_server/data/sessions.db-wal
demo_api_server/data/sessions-lmdb/

# Portable encrypted credential vault (Phase 269) — encrypted at rest but
# NEVER commit. Vault password is required to decrypt and lives only in
# the operator's head / 1Password / direnv. Encrypted-at-rest means an
# accidental commit is recoverable via password rotation, but .gitignore
# is the primary defense.
secrets.vault
secrets.vault.tmp
secrets.vault.audit.log
secrets.vault.pre-rebootstrap-*

# Temporary test scripts
banking_api_server/_test_*.js

