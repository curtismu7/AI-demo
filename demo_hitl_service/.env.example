# banking-hitl-service — environment variables

PORT=3009
HOST=0.0.0.0

# =============================================================================
# NOTIFICATION MODE
# Options: log (dev, no external calls), ciba (PingOne push/email), email (SMTP via BFF)
# =============================================================================
HITL_NOTIFY_MODE=log

# URL shown in approval notifications — must reach the OLB dashboard
HITL_DASHBOARD_URL=https://api.ping.demo:4000/dashboard/approve

# =============================================================================
# CIBA (when HITL_NOTIFY_MODE=ciba)
# =============================================================================
PINGONE_CIBA_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/bc-authorize
HITL_CLIENT_ID=your-hitl-client-id
HITL_CLIENT_SECRET=your-hitl-client-secret

# =============================================================================
# EMAIL (when HITL_NOTIFY_MODE=email)
# Email notifications are sent via the BFF's internal email endpoint
# =============================================================================
BANKING_API_BASE_URL=https://api.ping.demo:3001

# =============================================================================
# CORS
# Comma-separated origins allowed to call this service (OLB App + MCP Gateway)
# Defaults: UI (api.ping.demo:4000), BFF (api.ping.demo:3001), MCP Gateway (localhost:3005)
# =============================================================================
HITL_ALLOWED_ORIGINS=https://api.ping.demo:4000,https://api.ping.demo:3001,http://localhost:3005
