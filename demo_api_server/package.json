{
  "name": "banking-api-server",
  "version": "1.0.0",
  "description": "Simple banking API server with admin UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:unit": "jest --testPathPattern='step-up-gate|authorize-gate|runtime-settings-api|transaction-flows|demo-scenario-api' --forceExit --verbose",
    "test:auth": "jest --testPathPattern='auth|oauth-callback|oauth-error-handling|oauth-scope-integration|scope-integration' --forceExit --verbose",
    "test:all": "jest --forceExit --verbose",
    "test:watch": "jest --watch",
    "test:token-compliance": "jest --testPathPattern=token-structure-validation --forceExit --verbose",
    "test:coverage": "jest --forceExit --coverage",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:real": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand",
    "test:real:banking": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/banking",
    "test:real:retail": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/retail",
    "test:real:sporting-goods": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/sporting-goods",
    "test:real:healthcare": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/healthcare",
    "test:real:workforce": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/workforce",
    "test:real:admin": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/admin",
    "test:real:shared": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/shared",
    "test:real:smoke": "RUN_REAL_TESTS=true jest --config=jest.real.config.js --runInBand --testPathPattern=real/shared/health",
    "test:oauth": "./run-oauth-integration-tests.sh",
    "test:oauth-scope": "jest --testPathPattern=oauth-scope-integration.test.js --verbose --forceExit",
    "test:oauth-e2e": "jest --testPathPattern=oauth-e2e-integration.test.js --verbose --forceExit",
    "test:mcp-inspector": "jest --testPathPattern=mcp-inspector --forceExit --verbose",
    "test:bff-tokens": "jest --testPathPattern='redisWireUrl|bffSessionGating' --forceExit --verbose",
    "test:session": "jest --testPathPattern='authSession|authStateCookie|bffSessionGating|session-store-resilience|oauth-e2e-integration' --forceExit",
    "test:chips": "jest --testPathPattern='extractChips|allChips.pipeline.integration' --forceExit",
    "verify:token-exchange": "node scripts/verify-token-exchange.js",
    "verify:scopes": "node scripts/verify-scope-configuration.js",
    "verify:scopes:fix": "node scripts/verify-scope-configuration.js --fix",
    "test:pingone-token-integration": "jest --testPathPattern=token-exchange-pingone --forceExit",
    "test:live": "RUN_LIVE_TESTS=true jest --testPathPattern=live-pingone-integration --forceExit --no-coverage",
    "test:live:token": "RUN_LIVE_TESTS=true RUN_PINGONE_TOKEN_INTEGRATION=true jest --testPathPattern=\"token-exchange-pingone|dual-token-exchange-live\" --forceExit --no-coverage --verbose",
    "token:extract": "node scripts/extract-browser-token.js",
    "test:pingone": "jest --testPathPattern='pingoneTestRoutes' --forceExit --no-coverage && RUN_LIVE_TESTS=true jest --testPathPattern=live-pingone-integration --forceExit --no-coverage",
    "test:scope-assignments": "node test-scope-assignments.js",
    "test:oauth-provider-scopes": "node test-oauth-provider-scopes.js",
    "data:export-bootstrap": "node scripts/exportBootstrapData.js",
    "data:export": "node scripts/exportMigrationBundle.js",
    "data:import": "node scripts/importMigrationBundle.js",
    "data:preflight": "node scripts/importMigrationBundle.js --preflight-only",
    "pingone:bootstrap": "node scripts/bootstrapPingOne.js",
    "pingone:bootstrap:ci": "node scripts/bootstrapPingOne.js --non-interactive",
    "pingone:setup:trat": "node scripts/setupTratClaims.js",
    "pingone:cleanup": "node scripts/cleanupPingOneApps.js",
    "scopes:doc": "node scripts/generate-scope-doc.js",
    "setup:fresh": "node scripts/setupFresh.js",
    "vault:create": "node scripts/vault.js create",
    "vault:get": "node scripts/vault.js get",
    "vault:set": "node scripts/vault.js set",
    "vault:list": "node scripts/vault.js list",
    "vault:delete": "node scripts/vault.js delete",
    "vault:rotate": "node scripts/vault.js rotate",
    "vault:migrate-from-env": "node scripts/vault-migrate.js",
    "build": "echo 'API server - no build required'",
    "install-client": "cd ../demo_api_ui && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "dependencies": {
    "@inquirer/password": "^5.0.13",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint": "^1.0.2",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.4",
    "argon2": "^0.44.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "commander": "^14.0.3",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.3.1",
    "lmdb": "^3.5.4",
    "morgan": "^1.10.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.21.2",
    "redis": "^5.11.0",
    "tar": "^7.5.15",
    "uuid": "^14.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "glob": "^9.3.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "banking",
    "api",
    "rest",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  }
}
