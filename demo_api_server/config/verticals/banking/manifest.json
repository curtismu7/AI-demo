  "featurePage": {
    "mcpTool": "show_mortgage",
    "pageTitle": "Mortgage Account",
    "badgeLabel": "API-KEY PATH",
    "accentColor": "#ca8a04",
    "dataKey": "mortgage",
    "fields": [
      {
        "label": "Property",
        "path": "propertyAddress"
      },
      {
        "label": "Term",
        "path": "term"
      },
      {
        "label": "Origination date",
        "path": "originationDate"
      },
      {
        "label": "Interest rate",
        "path": "interestRate",
        "format": "percent"
      },
      {
        "label": "Original loan",
        "path": "loanAmount",
        "format": "money"
      },
      {
        "label": "Current balance",
        "path": "currentBalance",
        "format": "money",
        "accent": true
      },
      {
        "label": "Monthly payment",
        "path": "monthlyPayment",
        "format": "money"
      },
      {
        "label": "Next payment due",
        "path": "nextPaymentDate"
      }
    ],
    "sectionTitle": "Loan details",
    "emptyPrompt": "show mortgage data",
    "scopeError": "The agent's access token does not carry the mortgage:read scope, so the gateway refused the API key swap. Sign out and sign back in to consent to mortgage access, then try \"Show Mortgage Data\" again."
  },
