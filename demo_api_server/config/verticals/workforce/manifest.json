  "scopes": {
    "read": "read",
    "write": "write",
    "transfer": "transfer",
    "featureScope": "expense:read"
  },
  "render": {
    "view_benefits": { "type": "table", "columns": [ { "label": "Benefit", "path": "name" }, { "label": "Plan", "path": "planType" }, { "label": "Status", "path": "enrollmentStatus" } ] },
    "pto_balance": { "type": "fieldList", "title": "PTO", "fields": [ { "label": "Balance", "path": "balance", "format": "count" }, { "label": "Sick leave", "path": "sickLeave", "format": "count" }, { "label": "Accrued YTD", "path": "accruedYtd", "format": "count" } ] },
    "list_expenses": { "type": "table", "columns": [ { "label": "Category", "path": "category" }, { "label": "Amount", "path": "amount", "format": "money" }, { "label": "Status", "path": "status" } ] },
    "submit_expense": { "type": "card", "title": "Expense Submitted", "fields": [ { "label": "Category", "path": "category" }, { "label": "Amount", "path": "amount", "format": "money" }, { "label": "Status", "path": "status" } ] },
    "request_time_off": { "type": "card", "title": "Time Off Requested", "fields": [ { "label": "Days", "path": "days", "format": "count" }, { "label": "Remaining", "path": "remaining", "format": "count" } ] }
  },
  "featurePage": {
    "mcpTool": "show_expense_report",
    "pageTitle": "Expense Report",
    "badgeLabel": "API-KEY PATH",
    "accentColor": "#4c1d95",
    "dataKey": "expenseReport",
    "fields": [
      {
        "label": "Report ID",
        "path": "reportId"
      },
      {
        "label": "Category",
        "path": "category"
      },
      {
        "label": "Description",
        "path": "description"
      },
      {
        "label": "Amount",
        "path": "amount",
        "format": "money",
        "accent": true
      },
      {
        "label": "Submitted",
        "path": "submittedDate"
      },
      {
        "label": "Status",
        "path": "status"
      },
      {
        "label": "Approver",
        "path": "approver"
      },
      {
        "label": "Reimbursement date",
        "path": "reimbursementDate"
      }
    ],
    "sectionTitle": "Report details",
    "emptyPrompt": "show expense report",
    "scopeError": "The agent's access token does not carry the expense:read scope. Sign out and sign back in to consent to expense report access, then try \"Show Expense Report\" again."
  },
