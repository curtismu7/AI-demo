      { "id": "wf8", "label": "When should I use my PTO?", "message": "What's the best time of year for a sabbatical?", "mode": "llm" },
      { "id": "wf9", "label": "Right medical plan?", "message": "Do I have the right insurance plan for my needs?", "mode": "llm" },
      { "id": "wf10", "label": "Which expenses are pending?", "message": "What's still waiting on my manager's sign-off?", "mode": "llm" }
