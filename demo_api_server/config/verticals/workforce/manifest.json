    "hero": {
      "cards": [
        {
          "label": "Next Pay Date",
          "dataKey": "heroStats.nextPayDate",
          "format": "date"
        },
        {
          "label": "PTO Balance",
          "dataKey": "heroStats.ptoBalance",
          "format": "count"
        },
        {
          "label": "Open Enrollments",
          "dataKey": "heroStats.openEnrollments",
          "format": "count"
