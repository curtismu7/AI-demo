    "logoPath": null
  },
  "theme": {
    "cssVars": {
      "--app-primary-red": "#b91c1c",
      "--app-primary-red-hover": "#991b1b",
      "--app-primary-red-mid": "#ef4444",
      "--app-primary-red-border": "#dc2626",
      "--brand-dashboard-header-start": "#b91c1c",
      "--brand-dashboard-header-end": "#dc2626",
