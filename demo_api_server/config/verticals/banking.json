      { "label": "Origination date",   "path": "originationDate" },
      { "label": "Interest rate",      "path": "interestRate",  "format": "pct" },
      { "label": "Original loan",      "path": "loanAmount",    "format": "money" },
      { "label": "Current balance",    "path": "currentBalance","format": "money", "accent": true },
      { "label": "Monthly payment",    "path": "monthlyPayment","format": "money" },
      { "label": "Next payment due",   "path": "nextPaymentDate" }
