  "scopes": {
    "read": "read",
    "write": "write",
    "transfer": "transfer",
    "featureScope": "expense:read"
  },
  "featurePage": {
    "mcpTool": "show_expense_report",
    "pageTitle": "Expense Report",
    "badgeLabel": "API-KEY PATH",
    "accentColor": "#4c1d95",
    "accentBg": "rgba(76, 29, 149, 0.06)",
    "accentLight": "#faf5ff",
    "accentCode": "#ede9fe",
    "accentText": "#2e1065",
    "accentAccentText": "#4c1d95",
    "dataKey": "expenseReport",
    "fields": [
      { "label": "Report ID",          "path": "reportId" },
      { "label": "Category",           "path": "category" },
      { "label": "Description",        "path": "description" },
      { "label": "Amount",             "path": "amount",             "format": "money", "accent": true },
      { "label": "Submitted",          "path": "submittedDate" },
      { "label": "Status",             "path": "status" },
      { "label": "Approver",           "path": "approver" },
      { "label": "Reimbursement date", "path": "reimbursementDate" }
    ],
    "sectionTitle": "Report details",
    "emptyPrompt": "show expense report",
    "scopeError": "The agent's access token does not carry the expense:read scope. Sign out and sign back in to consent to expense report access, then try \"Show Expense Report\" again."
  },
  "demoUsers": {
