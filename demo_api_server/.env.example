# Banking API Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# This file documents every variable the server uses, using the EXACT names
# that bootstrap (npm run pingone:bootstrap) writes to .env.
#
# Usage:
#   Run bootstrap to generate a populated .env:
#     cd demo_api_server && npm run pingone:bootstrap
#   Or copy this file and fill in secrets manually:
#     cp .env.example .env
#
# Default local host: https://api.ping.demo (HTTPS via mkcert)
#   BFF binds on :3001 — actual server listener
#   UI runs on  :4000  — also where users land in the browser
#   PINGONE_PUBLIC_APP_URL defaults to the UI port (:4000) because OAuth
#   callbacks land in the browser; CRA proxy (setupProxy.js) forwards
#   /api/auth/oauth/callback from :4000 → BFF :3001.
#
# Override any value via the /setup page (saved to LMDB, survives .env loss)
# or by editing this file (requires server restart).
#
# SoT: docs/PINGONE_CONFIG.md — canonical PingOne entity IDs and audiences.
# NEVER commit this file with real secrets. .env is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# CORE PINGONE CONFIGURATION
# =============================================================================
# PingOne environment UUID — Admin → Environments → (env) → Environment ID
PINGONE_ENVIRONMENT_ID=

# Region TLD: com (default) | eu | ca | com.au | asia | sg
PINGONE_REGION=com

# =============================================================================
# SESSION / ENCRYPTION
# =============================================================================
# Strong random secret for Express session signing and config encryption.
# Bootstrap generates this automatically and preserves it on re-runs.
# Generate manually: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BOOTSTRAP_ALLOWLIST: always read from .env, never overridden by LMDB.
SESSION_SECRET=

# =============================================================================
# ADMIN OAUTH APP  (Demo Admin App — staff / BFF login)
# =============================================================================
# Web Application in PingOne with grant types: authorization_code, refresh_token, token_exchange
# Token Endpoint Auth Method: CLIENT_SECRET_POST
PINGONE_ADMIN_CLIENT_ID=
PINGONE_ADMIN_CLIENT_SECRET=
# Redirect URI — auto-derived from PINGONE_PUBLIC_APP_URL; uncomment only to override
# PINGONE_ADMIN_REDIRECT_URI=https://api.ping.demo:4000/api/auth/oauth/callback

# Token endpoint auth method: 'post' (CLIENT_SECRET_POST, PingOne default for web apps)
# Override to 'basic' only for older PingOne apps configured with CLIENT_SECRET_BASIC.
PINGONE_ADMIN_TOKEN_ENDPOINT_AUTH=post

# =============================================================================
# USER OAUTH APP  (Demo User App — end-user / customer login)
# =============================================================================
# Web Application in PingOne with grant types: authorization_code, refresh_token
# Token Endpoint Auth Method: CLIENT_SECRET_POST
PINGONE_USER_CLIENT_ID=
PINGONE_USER_CLIENT_SECRET=
# Redirect URI — auto-derived from PINGONE_PUBLIC_APP_URL; uncomment only to override
# PINGONE_USER_REDIRECT_URI=https://api.ping.demo:4000/api/auth/oauth/user/callback

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=development

# =============================================================================
# FRONTEND / PUBLIC URLs
# =============================================================================
# Public origin where users open the app in their browser. Drives ALL OAuth
# redirect URIs automatically (callbacks must land at the browser origin).
# Register these in PingOne app → Redirect URIs:
#   Admin redirect: {PINGONE_PUBLIC_APP_URL}/api/auth/oauth/callback
#   User  redirect: {PINGONE_PUBLIC_APP_URL}/api/auth/oauth/user/callback
PINGONE_PUBLIC_APP_URL=https://api.ping.demo:4000

# UI URLs — used by BFF to redirect after login/logout.
# Default: same origin as PINGONE_PUBLIC_APP_URL.
REACT_APP_CLIENT_URL=https://api.ping.demo:4000
FRONTEND_ADMIN_URL=https://api.ping.demo:4000/admin
FRONTEND_DASHBOARD_URL=https://api.ping.demo:4000/dashboard

# =============================================================================
# RESOURCE SERVER AUDIENCES
# Audience (aud) values must match the resource server strings registered in PingOne.
# See docs/PINGONE_CONFIG.md → Resource Servers for the full table.
# =============================================================================

# Demo API resource — end-user access token audience.
# Bootstrap writes: ENDUSER_AUDIENCE=enduser.ping.demo
ENDUSER_AUDIENCE=enduser.ping.demo

# MCP Resource URI — the audience the BFF exchanges user tokens into.
# In passthrough mode (MCP_GW_PASSTHROUGH_TO_MCP_SERVER=true) this is the
# MCP Gateway audience so the inbound token already carries the right aud for
# the gateway. When the gateway does a second exchange, it re-targets mcpserver.
MCP_RESOURCE_URI=mcpgateway.ping.demo

# Demo MCP Server resource audience — used for direct (non-gateway) MCP calls
# and as the final audience in two-exchange delegation (Exchange #2 result).
MCP_SERVER_RESOURCE_URI=mcpserver.ping.demo

# =============================================================================
# MCP TOKEN EXCHANGER  (Demo MCP Exchanger — RFC 8693 legacy actor, currently unused)
# =============================================================================
# Worker-style app used as the actor token source in the original single-exchange flow.
# The two-exchange flow uses PINGONE_AI_AGENT_CLIENT_ID + MCP_GW_CLIENT_ID instead.
# Kept for backwards compatibility; callers alias this as AGENT_OAUTH_CLIENT_ID (see below).
PINGONE_MCP_EXCHANGER_CLIENT_ID=
PINGONE_MCP_EXCHANGER_CLIENT_SECRET=

# =============================================================================
# MCP GATEWAY  (Demo MCP Gateway — :3005)
# =============================================================================
# WEB_APP in PingOne with grant types: client_credentials, token_exchange
# Acts as the Exchange #2 actor in the two-exchange RFC 8693 delegation chain.
MCP_GW_CLIENT_ID=
MCP_GW_CLIENT_SECRET=
# Audience for the MCP Gateway's client-credentials actor token (Exchange #2 actor)
MCP_GW_RESOURCE_URI=mcpgateway.ping.demo
# Token endpoint auth method for the gateway app: 'post' (CLIENT_SECRET_POST)
MCP_GW_TOKEN_ENDPOINT_AUTH_METHOD=post
# When true, gateway proxies MCP requests directly to the MCP server without
# performing a downstream token re-exchange. Used in local dev.
MCP_GW_PASSTHROUGH_TO_MCP_SERVER=true

# HTTP base URL of the MCP Gateway — triggers gateway-audience token exchange
# in agentMcpTokenService._resolveFinalMcpAudience.
# Local dev: https://127.0.0.1:3005 (TLS via mkcert, loopback only)
MCP_GATEWAY_HTTP_URL=https://127.0.0.1:3005

# WebSocket URL the BFF dials to reach the MCP server (or gateway in passthrough mode).
# Local dev: wss://127.0.0.1:3005 (routes through gateway)
# Direct MCP (no gateway): ws://localhost:8080
MCP_SERVER_URL=wss://127.0.0.1:3005

# Dev-only: skip TLS verification on the gateway /health probe and MCP WebSocket.
# Hard-ignored in production (NODE_ENV=production). Set via LMDB or this file.
# run.sh sets NODE_EXTRA_CA_CERTS instead — prefer that over this flag.
# GATEWAY_HEALTH_PROBE_INSECURE=true

# Optional: validate PingOne resource servers and scopes at startup.
# Checks all four Demo resource servers (audience values) and their scopes
# against the reference values in docs/PINGONE_CONFIG.md.
# Requires PINGONE_WORKER_CLIENT_ID + PINGONE_WORKER_CLIENT_SECRET to be set.
# Non-blocking — warnings only, never prevents startup.
# PINGONE_VALIDATE_ON_STARTUP=true

# =============================================================================
# DEMO AGENT SERVICE  (Demo Agent — :3006, worker app)
# =============================================================================
# WORKER app in PingOne with grant type: client_credentials
# Used by the agent service for internal BFF→agent auth and management API calls.
AGENT_CLIENT_ID=
AGENT_CLIENT_SECRET=

# =============================================================================
# RFC 8693 TWO-EXCHANGE DELEGATION CHAIN
# ─────────────────────────────────────────────────────────────────────────────
# Exchange #1: AI Agent (d21c5124) exchanges:
#   subject_token = user access token (aud=enduser.ping.demo)
#   actor_token   = AI Agent CC token (aud=agentgateway.ping.demo)
#   → intermediate token: aud=agentgateway.ping.demo, act.sub=AI_AGENT_CLIENT_ID
#
# Exchange #2: MCP Exchanger (d3f8fead) exchanges:
#   subject_token = intermediate token (aud=agentgateway.ping.demo)
#   actor_token   = MCP Gateway CC token (aud=mcpgateway.ping.demo)
#   → final MCP token: aud=mcpgateway.ping.demo, act.sub=MCP_GW_CLIENT_ID
#
# See docs/PINGONE_CONFIG.md → RFC 8693 Token Exchange Chain for full diagram.
# =============================================================================

# Demo AI Agent — the RFC 8693 Exchange #1 actor
# WEB_APP in PingOne: authorization_code, client_credentials, token_exchange
PINGONE_AI_AGENT_CLIENT_ID=
PINGONE_AI_AGENT_CLIENT_SECRET=

# Audience values for the exchange chain
PINGONE_RESOURCE_AGENT_GATEWAY_URI=agentgateway.ping.demo
PINGONE_RESOURCE_MCP_GATEWAY_URI=mcpgateway.ping.demo

# Intermediate audience after Exchange #1 (same as PINGONE_RESOURCE_AGENT_GATEWAY_URI)
AI_AGENT_INTERMEDIATE_AUDIENCE=agentgateway.ping.demo

# Final audience after Exchange #2 — in passthrough mode this is the gateway
# audience; the gateway owns the last hop to the MCP server.
PINGONE_RESOURCE_TWO_EXCHANGE_URI=mcpgateway.ping.demo

# Scope the AI Agent requests on the Agent Gateway resource in Exchange #1
TWO_EXCHANGE_INTERMEDIATE_SCOPE=agent:invoke

# ── Alias block — kept in sync with PINGONE_MCP_EXCHANGER_* above ────────────
# Some internal callers resolve the MCP Exchanger credentials under these names.
# Values MUST stay identical to PINGONE_MCP_EXCHANGER_CLIENT_ID/SECRET.
AGENT_OAUTH_CLIENT_ID=
AGENT_OAUTH_CLIENT_SECRET=

# =============================================================================
# ADMIN TOKEN EXCHANGE
# =============================================================================
# Use RFC 8693 token exchange for admin sessions (experimental)
ff_admin_token_exchange=true
# Access token lifetime (seconds) for admin OAuth app
ADMIN_TOKEN_LIFETIME=7200
# Refresh token lifetime (seconds) for admin OAuth app
ADMIN_REFRESH_TOKEN_LIFETIME=86400

# =============================================================================
# TOKEN ENDPOINT AUTH METHODS
# =============================================================================
# ARCHITECTURE: every PingOne client connection uses CLIENT_SECRET_POST ('post').
# The ONLY exception is the Worker Token CC client (WORKER type, Management API)
# which stays CLIENT_SECRET_BASIC ('basic'). See docs/PINGONE_CONFIG.md.
PINGONE_ADMIN_TOKEN_ENDPOINT_AUTH=post
PINGONE_INTROSPECTION_AUTH_METHOD=post

# =============================================================================
# DEMO USERS  (created by bootstrap — passwords match PingOne)
# =============================================================================
DEMO_USER_USERNAME=demoUser
DEMO_USER_PASSWORD=2Federate!
DEMO_ADMIN_USERNAME=demoAdmin
DEMO_ADMIN_PASSWORD=2Federate!

# =============================================================================
# WORKER CREDENTIALS  (Demo Worker Token App — Management API)
# =============================================================================
# WORKER app in PingOne with grant type: client_credentials
# Token endpoint auth method: CLIENT_SECRET_BASIC (only exception to post rule above)
# Used for PingOne Management API calls (user management, app config, provisioning).
PINGONE_WORKER_CLIENT_ID=
PINGONE_WORKER_CLIENT_SECRET=

# =============================================================================
# INTERNAL SERVICE SECRET
# =============================================================================
# Shared secret between BFF (:3001) and demo_agent_service (:3006).
# Used in x-internal-gateway-secret header for BFF→agent internal calls.
# Bootstrap generates this; set to any strong random value.
BFF_INTERNAL_SECRET=

# =============================================================================
# OPTIONAL: MFA CONFIGURATION
# =============================================================================
# MFA Policy ID from PingOne — Policies → Sign-On Policies → (policy) → Policy ID
# PINGONE_MFA_POLICY_ID=
# ACR value to request for MFA (must match a Sign-On Policy name in PingOne)
# PINGONE_MFA_ACR_VALUE=Multi_factor

# =============================================================================
# OPTIONAL: PORTABLE ENCRYPTED CREDENTIAL VAULT
# =============================================================================
# The vault keeps secrets out of .env. Drop a secrets.vault file at the repo
# root (created via `npm run vault:set ...`) and provide the unlock password.
# The BFF reads the vault at startup, merges entries into configStore, then
# deletes VAULT_PASSWORD from process.env immediately.
#
# ⚠️  No password recovery. Lose the password → rebuild from source secrets.
# Quote secrets (CLAUDE.md rule): special chars like ~ . - break shell parsing.
# Vercel: vault is SKIPPED when VERCEL=1 — use Encrypted Environment Variables.
#
# VAULT_PATH=
# VAULT_PASSWORD=

# =============================================================================
# OPTIONAL: HELIX LLM  (defaults to the shared Super Banking demo agent)
# =============================================================================
# Four Helix values are committed as defaults in configStore.js so this repo
# works out of the box for the public demo. Only HELIX_API_KEY is required.
#
# Priority order for the API key:
#   1. HELIX_API_KEY here (or shell env) — wins
#   2. /setup → LLM Provider → Helix — saved in LMDB configStore
#   3. <HELIX_AGENT_ID>.json in repo root / ~/Documents / ~/Downloads
#      (Helix Console → API Keys → Download; file is gitignored)
HELIX_API_KEY=
# Override only when pointing at a different Helix tenant:
# HELIX_BASE_URL=https://openam-helix.forgeblocks.com
# HELIX_ENVIRONMENT_ID=fe213c3c-9c1d-4bdb-954a-a22879dad26d
# HELIX_AGENT_ID=LLM2
# HELIX_PROMPT_FIELD_ID=textInputa7c39a0e8292

# =============================================================================
# OPTIONAL: OLLAMA  (local LLM fallback for NL intent)
# =============================================================================
# Defaults to http://localhost:11434 when unset.
# Set to a remote host for shared/hosted Ollama instances.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# =============================================================================
# OPTIONAL: PINGONE RECOGNIZE  (biometric face auth)
# =============================================================================
# Obtain from Recognize tenant dashboard (SDK Customer Dashboard).
# RECOGNIZE_API_KEY=
# RECOGNIZE_TENANT_NAME=
# RECOGNIZE_BASE_URL=https://authentication-service.eks.core-production.saas-us-east.keyless.technology

# =============================================================================
# OPTIONAL: SESSION STORE
# =============================================================================
# Default: LMDB at demo_api_server/data/sessions-lmdb/ (no config needed).
# For multi-process / Vercel deployments, use one of:
# REDIS_URL=
# KV_URL=

# =============================================================================
# OPTIONAL: ANTHROPIC  (Claude as agent reasoning provider)
# =============================================================================
# Set LLM_PROVIDER=anthropic in demo_agent_service/.env and provide key here.
# The BFF forwards this to :3006 — it never reaches the browser.
# ANTHROPIC_API_KEY=

# =============================================================================
# DEBUG  (set to false in production)
# =============================================================================
PINGONE_DEBUG_OAUTH=false
DEBUG_TOKENS=false
DEBUG_SCOPES=false
# WARNING: Must be false in production — server exits at startup if NODE_ENV=production
SKIP_TOKEN_SIGNATURE_VALIDATION=false
