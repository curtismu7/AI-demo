# Banking API Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.example .env
#   Fill in the secrets (lines without a default value)
#   Start locally:  ./run-bank.sh   (or `npm start` from this directory)
#
# Default local host:  https://api.ping.demo (HTTPS via mkcert)
#   BFF binds on :3001 — actual server listener
#   UI runs on  :4000  — also where users land in the browser
#   PINGONE_PUBLIC_APP_URL defaults to the UI port (:4000) because OAuth
#   callbacks land in the browser; CRA proxy (setupProxy.js) forwards
#   /api/auth/oauth/callback from :4000 → BFF :3001.
# Override via the /setup page or by editing this file.
#
# NEVER commit this file with real secrets. .env is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# MCP SERVER
# =============================================================================
# WebSocket URL of the banking MCP server (local dev: ws://localhost:8080)
PINGONE_MCP_SERVER_URL=ws://localhost:8080

# =============================================================================
# PINGONE CONFIGURATION
# =============================================================================
# Your PingOne environment UUID — Admin → Environments → (env) → Environment ID
PINGONE_ENVIRONMENT_ID=

# Region TLD: com (default) | eu | ca | com.au | asia | sg
PINGONE_REGION=com

# =============================================================================
# ADMIN OAUTH APP  (Web Application in PingOne — staff / BFF login)
# =============================================================================
PINGONE_ADMIN_CLIENT_ID=
PINGONE_ADMIN_CLIENT_SECRET=
# Token endpoint auth method: 'basic' (default, header) | 'post' (form body)
# Must match PingOne app → Configuration → Token Endpoint Authentication Method
PINGONE_ADMIN_TOKEN_ENDPOINT_AUTH=basic

# Redirect URI: auto-derived from PINGONE_PUBLIC_APP_URL below — uncomment only to override.
# PINGONE_ADMIN_REDIRECT_URI=https://api.ping.demo:4000/api/auth/oauth/callback

# =============================================================================
# USER OAUTH APP  (Web Application in PingOne — end-user / customer login)
# =============================================================================
PINGONE_USER_CLIENT_ID=
PINGONE_USER_CLIENT_SECRET=

# Redirect URI: auto-derived from PINGONE_PUBLIC_APP_URL below — uncomment only to override.
# PINGONE_USER_REDIRECT_URI=https://api.ping.demo:4000/api/auth/oauth/user/callback

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
# Strong random secret for Express session signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PINGONE_SESSION_SECRET=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=development

# =============================================================================
# FRONTEND URLs
# =============================================================================
# UI dev server runs on https://api.ping.demo:4000 via run-bank.sh.
# Proxies /api → BFF on PORT above (same host, different port).
REACT_APP_CLIENT_URL=https://api.ping.demo:4000
FRONTEND_ADMIN_URL=https://api.ping.demo:4000/admin
FRONTEND_DASHBOARD_URL=https://api.ping.demo:4000/dashboard

# ── PINGONE_PUBLIC_APP_URL ────────────────────────────────────────────────────
# Public origin where users open the app in their browser. Drives ALL OAuth
# redirect URIs automatically (callbacks must land at the browser origin).
# Default: https://api.ping.demo:4000 (UI port — CRA proxy forwards /api/* to BFF :3001).
# Register these in PingOne app → Redirect URIs:
#   Admin redirect:  {PINGONE_PUBLIC_APP_URL}/api/auth/oauth/callback
#   User  redirect:  {PINGONE_PUBLIC_APP_URL}/api/auth/oauth/user/callback
PINGONE_PUBLIC_APP_URL=https://api.ping.demo:4000

# =============================================================================
# ROLE CONFIGURATION
# =============================================================================
PINGONE_ADMIN_ROLE=admin
PINGONE_USER_ROLE=customer
PINGONE_DEFAULT_USER_TYPE=customer

# =============================================================================
# PINGONE TOKEN AUDIENCE CONFIGURATION (RFC 8693 §2.3 — resource/audience)
# =============================================================================
PINGONE_AUDIENCE_ENDUSER=https://banking-api.banking-demo.com
PINGONE_AUDIENCE_AI_AGENT=https://banking-ai-agent.banking-demo.com
PINGONE_SCOPE_AI_AGENT=ai:agent:read

# =============================================================================
# PINGONE AGENT CLIENT CREDENTIALS — Actor Token source (RFC 8693 §2.2)
# =============================================================================
# Used as the actor token in RFC 8693 2-exchange delegation.
PINGONE_AGENT_CLIENT_ID=
PINGONE_AGENT_CLIENT_SECRET=
PINGONE_AGENT_CLIENT_SCOPES=openid
PINGONE_USE_AGENT_ACTOR_FOR_MCP=true

# PINGONE AI Agent worker app — Actor Token source (RFC 8693 §2.2) for MCP tool scopes
PINGONE_AI_AGENT_CLIENT_ID=
PINGONE_AI_AGENT_CLIENT_SECRET=

# =============================================================================
# PINGONE WORKER TOKEN  (Worker App for PingOne Management API calls)
# =============================================================================
# Used by PingOne Test page and MFA Test page to verify apps, resources, scopes, users
# App Type: WORKER (no redirect URIs, client credentials only)
PINGONE_WORKER_TOKEN_CLIENT_ID=
PINGONE_WORKER_TOKEN_CLIENT_SECRET=
# Token endpoint auth method: 'basic' (default, header) | 'post' (form body)
PINGONE_WORKER_TOKEN_AUTH_METHOD=basic

# =============================================================================
# PINGONE MANAGEMENT API  (Worker App for Management API access)
# =============================================================================
# Used by MFA Test page for device authentication and user management
# App Type: WORKER (no redirect URIs, client credentials only)
PINGONE_MANAGEMENT_CLIENT_ID=
PINGONE_MANAGEMENT_CLIENT_SECRET=

# =============================================================================
# PINGONE MFA CONFIGURATION
# =============================================================================
# MFA Policy ID from PingOne for device authentication
# Find in PingOne: Policies → Sign-On Policies → (policy) → Policy ID
PINGONE_MFA_POLICY_ID=
# ACR value to request for MFA (must match a Sign-On Policy name in PingOne)
PINGONE_MFA_ACR_VALUE=Multi_factor

# =============================================================================
# PINGONE MCP TOKEN EXCHANGER — performs RFC 8693 §3.1 Token Exchange #1
# =============================================================================
# Used for token exchange to get MCP server access tokens
# App Type: AI_AGENT (client credentials, no redirect URIs)
PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_ID=
PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_SECRET=
PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_SCOPES=openid
# Token endpoint auth method: 'basic' (default, header) | 'post' (form body)
PINGONE_MCP_TOKEN_EXCHANGER_AUTH_METHOD=basic

# =============================================================================
# PINGONE TOKEN INTROSPECTION (Phase 91 - External MCP client access)
# =============================================================================
# RFC 7662 introspection endpoint for validating Bearer tokens from external clients
# Used by MCP gateway (Phase 91 Plan 02) to validate tokens before tool calls
PINGONE_INTROSPECTION_ENDPOINT=https://auth.pingone.com/v1/environments/{PINGONE_ENVIRONMENT_ID}/oauth2/introspect
# Worker app credentials (same as PINGONE_AGENT_CLIENT_ID / SECRET or dedicated worker app)
PINGONE_WORKER_CLIENT_ID=
PINGONE_WORKER_CLIENT_SECRET=

# =============================================================================
# PINGONE TOKEN EXCHANGE RESOURCES
# =============================================================================
# BFF resource URI — tokens arriving at this service must be issued for this audience.
# Audience validation is mandatory and fail-closed when this is set.
# bootstrapPingOne writes ENDUSER_AUDIENCE automatically; set PINGONE_RESOURCE_BFF_URI
# to override it explicitly (useful for non-standard deployments).
ENDUSER_AUDIENCE=enduser.ping.demo
# PINGONE_RESOURCE_BFF_URI=https://banking-api.banking-demo.com  # optional override

# Resource URI registered in PingOne for the MCP server (must match MCP server config)
PINGONE_RESOURCE_MCP_SERVER_URI=https://banking-mcp-server.banking-demo.com
PINGONE_RESOURCE_TWO_EXCHANGE_URI=https://banking-resource-server.banking-demo.com

# Resource URI registered in PingOne for the Device Authentications API
# Used for RFC 8693 token exchange to get Device Authentication scoped tokens
PINGONE_RESOURCE_DEVICE_AUTH_URI=https://device-auth.pingone.com

# PINGONE Resources for gateway and agent delegation chain
PINGONE_RESOURCE_AGENT_GATEWAY_URI=https://banking-agent-gateway.banking-demo.com
PINGONE_RESOURCE_MCP_GATEWAY_URI=https://banking-mcp-gateway.banking-demo.com

# Enable 2-exchange RFC 8693 delegation (User → Agent → MCP)
FF_TWO_EXCHANGE_DELEGATION=true

# MCP Gateway TLS — when the gateway serves an mkcert-issued cert (default
# local-dev setup), the BFF needs to trust the mkcert root CA to validate
# it. run-bank.sh launches the API server with NODE_EXTRA_CA_CERTS pointing
# at $(mkcert -CAROOT)/rootCA.pem, which resolves this. As a fallback if
# you're starting the BFF without run-bank.sh, uncomment the next line to
# skip TLS verification on the gateway /health probe (probe only — never
# widens to other gateway calls; refused in production by code at
# agentMcpTokenService.js).
# GATEWAY_HEALTH_PROBE_INSECURE=true

# =============================================================================
# PORTABLE ENCRYPTED CREDENTIAL VAULT (Phase 269)
# =============================================================================
# The vault is an OPTIONAL way to keep secrets out of .env. Drop a
# secrets.vault file at the repo root (created via `npm run vault:set ...`)
# and provide the unlock password via VAULT_PASSWORD here or in your shell.
# The BFF reads the vault at startup, copies every entry into the in-memory
# configStore cache, then deletes VAULT_PASSWORD from process.env.
#
# ⚠️  There is no password recovery. Lose the password → vault must be
# rebuilt from source secrets (regenerate Helix key, worker secrets, etc.).
#
# Quote secrets (CLAUDE.md rule): special chars like ~ . - break shell parsing.
# Examples:
#   VAULT_PATH="/etc/banking/secrets.vault"
#   VAULT_PASSWORD="your-strong-passphrase-here"
#
# Vercel: vault is SKIPPED when VERCEL=1 — use Encrypted Environment Variables.
# VAULT_PATH=
# VAULT_PASSWORD=

# =============================================================================
# HELIX LLM  (optional — defaults to the shared Super Banking demo agent)
# =============================================================================
# Four Helix values (base_url, environment_id, agent_id, prompt_field_id) are
# committed as defaults in banking_api_server/services/configStore.js so this
# repo works out of the box for the public demo. Only HELIX_API_KEY is missing.
#
# Three ways to provide the key, in priority order:
#   1. HELIX_API_KEY=...                 (this file or shell env — wins)
#   2. /setup → LLM Provider → Helix     (saved in SQLite configStore)
#   3. <HELIX_AGENT_ID>.json             (Helix Console → API Keys → Download)
#                                          searched in repo root, ~/Documents,
#                                          ~/Downloads — keyValue lifted from JSON
#
# Option 3 lets fresh clones run Helix without any setup step: drop the team
# LLM2.json next to README.md and start the server. The file is gitignored.
# Override the four non-secret values only if pointing at a different Helix tenant.
HELIX_API_KEY=
# HELIX_BASE_URL=https://openam-helix.forgeblocks.com
# HELIX_ENVIRONMENT_ID=fe213c3c-9c1d-4bdb-954a-a22879dad26d
# HELIX_AGENT_ID=LLM2
# HELIX_PROMPT_FIELD_ID=textInputa7c39a0e8292

# =============================================================================
# PINGONE RECOGNIZE  (biometric face auth — used by hitl_consent_mfa_mode=recognize)
# =============================================================================
# Obtain your API key from the Recognize tenant dashboard:
#   https://sdk-customer-dashboard.eks.core-production.saas-us-east.keyless.technology/
#   Access Control → Secret API Key → Create Secret API Key
#
# RECOGNIZE_BASE_URL defaults to the US region if unset:
#   US:      https://authentication-service.eks.core-production.saas-us-east.keyless.technology
#   EU:      https://authentication-service.eks.core-production.keyless.technology
#   LATAM:   https://authentication-service.eks.core-production.latam.keyless.technology
#   Sandbox: https://authentication-service-sandbox.eks.core-production.keyless.technology
RECOGNIZE_API_KEY=
RECOGNIZE_TENANT_NAME=
# RECOGNIZE_BASE_URL=https://authentication-service.eks.core-production.saas-us-east.keyless.technology

# =============================================================================
# SESSION STORE  (local dev uses SQLite; uncomment Redis for multi-process HA)
# =============================================================================
# Local default is SQLite at banking_api_server/data/sessions.db (no config needed).
# If you scale to multiple processes, uncomment one of:
#
# OR node-redis wire protocol (self-hosted / Railway Redis)
# REDIS_URL=
# KV_URL=

# =============================================================================
# DEBUG
# =============================================================================
PINGONE_DEBUG_OAUTH=true
DEBUG_TOKENS=true
DEBUG_SCOPES=true
# WARNING: Must be false in production — server exits at startup if NODE_ENV=production
SKIP_TOKEN_SIGNATURE_VALIDATION=false

# =============================================================================
# ANTHROPIC (Claude as agent reasoning provider)
# Set LLM_PROVIDER=anthropic in demo_agent_service/.env and provide a key here.
# The BFF forwards this to :3006 — it never reaches the browser.
# =============================================================================
ANTHROPIC_API_KEY=
