#!/usr/bin/env bash
# .husky/pre-commit
# Managed by Husky — runs before every commit.
# Warns about missing doc updates, blocks on exposed secrets, and runs UI tests when UI files change.

YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
RESET='\033[0m'

warn() { echo -e "${YELLOW}⚠  $1${RESET}"; }
info() { echo -e "${CYAN}   $1${RESET}"; }
error() { echo -e "${RED}✖  $1${RESET}"; }

# ── CONCURRENCY GUARD ──────────────────────────────────────────────────────
# Root cause of a real contamination incident: two agents/processes mutating
# one shared git index/worktree at once. lint-staged stash/pop (below)
# interleaved with a concurrent process's stash + branch-switch and restored
# foreign changes into the staged commit. lint-staged itself was not at
# fault — simultaneous index mutation was. This advisory lock makes that
# class of failure impossible: only one pre-commit may hold it.
#
# mkdir is atomic on POSIX (portable; macOS has no flock). The lock is
# released via an EXIT trap (normal exit, error, or signal). A crashed
# hook is recovered by a PID-liveness check so a single crash cannot
# permanently block commits.
GIT_DIR_PATH=$(git rev-parse --git-dir)
LOCK_DIR="${GIT_DIR_PATH}/superbank-precommit.lock"

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  LOCK_PID=$(cat "${LOCK_DIR}/pid" 2>/dev/null || echo "")
  if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
    error "Another pre-commit is running (PID ${LOCK_PID}) — refusing to commit."
    info "Concurrent commits on one worktree caused a known contamination bug."
    info "Wait for the other commit to finish, or stop the other agent/process."
    exit 1
  fi
  # Stale lock (holder is dead) — reclaim it.
  warn "Removing stale pre-commit lock (PID ${LOCK_PID:-unknown} not running)."
  rm -rf "$LOCK_DIR"
  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    error "Could not acquire pre-commit lock after reclaiming stale lock."
    exit 1
  fi
fi
echo "$$" > "${LOCK_DIR}/pid"
echo "$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" > "${LOCK_DIR}/branch"
# shellcheck disable=SC2064
trap "rm -rf '$LOCK_DIR'" EXIT

STAGED=$(git diff --cached --name-only)

# ── SECRET SCAN — block on known secret patterns ───────────────────────────
# Prevents committing hardcoded API keys/tokens (learned from Anthropic key exposure)
if git diff --cached -U0 | grep -qE '(sk-ant-api[0-9]|ghp_[A-Za-z0-9]{36}|AKIA[0-9A-Z]{16})'; then
  error "Possible API secret detected in staged changes!"
  info "Remove hardcoded secrets before committing."
  info "Use environment variables or .env.local (gitignored) instead."
  info "Run  git commit --no-verify  only if this is a false positive."
  echo ""
  exit 1
fi

# ── CHANGELOG check ────────────────────────────────────────────────────────
WARN_TRIGGERED=0

if ! echo "$STAGED" | grep -q "CHANGELOG.md"; then
  warn "CHANGELOG.md not staged."
  info "Add one line under [Unreleased] in the right category (Added/Fixed/Changed/Removed)."
  WARN_TRIGGERED=1
fi

# ── FEATURES check (only if a route, component, service, or middleware changed) ──
FEATURE_RELEVANT=$(echo "$STAGED" | grep -E \
  "routes/|components/|services/|middleware/|mcp_server/" | grep -v "__tests__" | grep -v "\.css$" || true)

if [ -n "$FEATURE_RELEVANT" ] && ! echo "$STAGED" | grep -q "FEATURES.md"; then
  warn "FEATURES.md not staged — but feature-related files changed:"
  echo "$FEATURE_RELEVANT" | head -5 | while read -r f; do info "$f"; done
  info "Update FEATURES.md if a feature was added, removed, or its test coverage changed."
  WARN_TRIGGERED=1
fi

# ── REGRESSION_LOG check (only if a test file was staged) ──────────────────
TEST_FILES=$(echo "$STAGED" | grep -E "\.test\.(js|ts)$" || true)

if [ -n "$TEST_FILES" ] && ! echo "$STAGED" | grep -q "REGRESSION_LOG.md"; then
  warn "Test files staged but REGRESSION_LOG.md not staged."
  info "If this test covers a production bug fix, add an entry to REGRESSION_LOG.md."
  WARN_TRIGGERED=1
fi

if [ "$WARN_TRIGGERED" -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}Run  git commit --no-verify  to skip these checks.${RESET}"
  echo ""
fi

# ── LINT STAGED FILES (auto-fix eslint and format issues) ────────────────────
if echo "$STAGED" | grep -q 'banking_api_ui/src'; then
  echo "Running lint-staged on UI files..."
  (cd banking_api_ui && npx lint-staged)
  if [ $? -ne 0 ]; then
    error "Lint-staged failed — commit blocked. Fix linting issues before committing."
    exit 1
  fi
fi

# ── UI UNIT TESTS (only when banking_api_ui/src files changed) ─────────────
if echo "$STAGED" | grep -q 'banking_api_ui/src'; then
  echo "UI files changed — running unit tests..."
  (cd banking_api_ui && npm run test:unit -- --watchAll=false --passWithNoTests --forceExit)
  if [ $? -ne 0 ]; then
    error "Unit tests failed — commit blocked. Fix tests before committing."
    exit 1
  fi
fi

# ── ENV COVERAGE — block if any .env var is unmapped in configStore ─────────
ENV_RELEVANT=$(echo "$STAGED" | grep -E \
  "demo_api_server/\.env$|services/configStore\.js$|scripts/check-env\.js$" || true)

if [ -n "$ENV_RELEVANT" ]; then
  echo "Env or configStore changed — running coverage check..."
  (cd demo_api_server && npx jest --testPathPattern='src/__tests__/configStore\.envCoverage' --no-coverage --forceExit --silent 2>/dev/null)
  if [ $? -ne 0 ]; then
    error "configStore env coverage check failed!"
    info "A variable in banking_api_server/.env is not mapped in configStore.getEffective()."
    info "Add it to envFallbackMap in banking_api_server/services/configStore.js."
    exit 1
  fi
  echo "  ✓ All .env vars are mapped in configStore"
fi

# Warnings are advisory only — never block on WARN_TRIGGERED.
exit 0
